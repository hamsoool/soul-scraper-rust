# Database Configuration
# Standard PostgreSQL URL. The Rust app accepts postgresql:// or postgres://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doe_scraper

# Scraper & Parser Settings
SYNC_INTERVAL_HOURS=24
HTTP_TIMEOUT_SECONDS=30
MAX_PDF_SIZE_BYTES=10485760

# Set to false on Render to disable the internal cloud scraper
ENABLE_SCRAPER_SCHEDULER=true

# API Key (set a value to protect endpoints; empty = no auth)
API_KEY=

# Server Host and Port
HOST=0.0.0.0
PORT=8000

# Logging (trace | debug | info | warn | error)
RUST_LOG=info
